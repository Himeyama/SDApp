<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SDApp.Views.GenerationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="420,*" Padding="20" ColumnSpacing="20">
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Generation_PromptLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="PromptTextBox" x:Uid="Generation_PromptTextBox" AcceptsReturn="True" Height="100"
                         TextWrapping="Wrap" />

                <TextBlock x:Uid="Generation_NegativePromptLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="NegativePromptTextBox" x:Uid="Generation_NegativePromptTextBox" AcceptsReturn="True" Height="70"
                         TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Generation_SamplerLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox x:Name="SamplerComboBox" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Generation_SeedLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox x:Name="SeedTextBox" x:Uid="Generation_SeedTextBox" />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock x:Uid="Generation_StepsLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Slider x:Name="StepsSlider" Minimum="1" Maximum="150" Value="20"
                            TickFrequency="10" ValueChanged="StepsSlider_ValueChanged" />
                    <TextBlock x:Name="StepsValueTextBlock" Text="20" Opacity="0.7" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock x:Uid="Generation_CfgScaleLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Slider x:Name="CfgScaleSlider" Minimum="0" Maximum="30" Value="7"
                            StepFrequency="0.5" TickFrequency="5" ValueChanged="CfgScaleSlider_ValueChanged" />
                    <TextBlock x:Name="CfgScaleValueTextBlock" Text="7.0" Opacity="0.7" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Generation_WidthLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <NumberBox x:Name="WidthNumberBox" Minimum="64" Maximum="2048"
                                   SmallChange="8" LargeChange="64" Value="512"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Generation_HeightLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <NumberBox x:Name="HeightNumberBox" Minimum="64" Maximum="2048"
                                   SmallChange="8" LargeChange="64" Value="512"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                </Grid>

                <Button x:Name="GenerateButton" HorizontalAlignment="Stretch"
                        Style="{ThemeResource AccentButtonStyle}" Click="GenerateButton_Click" IsEnabled="False" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" RowDefinitions="*,Auto">
            <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                <Grid>
                    <Image x:Name="ResultImageControl" Stretch="Uniform" Margin="8" />
                    <ProgressRing x:Name="GenerationProgressRing" IsActive="False"
                                  Width="48" Height="48" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
