<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Sodalite.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Sodalite"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Uid="MainWindow"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid.Resources>
            <Style x:Key="StatusBarIconButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="4" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Opacity" Value="0.7" />
            </Style>
        </Grid.Resources>

        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="48" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="16,0,0,0" Spacing="8">
                <Image Source="ms-appx:///Assets/AppIcon.ico" Width="16" Height="16"
                       VerticalAlignment="Center" />
                <TextBlock x:Uid="MainWindow_TitleBarText" Style="{ThemeResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ページ遷移を横スライドで見せるため Frame ではなく重ね置きの Grid を使う。
             GenerationPage はイベント購読済みの保持インスタンスをそのまま載せ続け、
             モデル選択ページを右から重ねてスライドイン/アウトさせる。 -->
        <Grid x:Name="RootHost" Grid.Row="1" />

        <Border x:Name="SetupOverlay" Grid.Row="1" Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="560" Spacing="16" Padding="24">
                <ProgressRing IsActive="True" Width="48" Height="48"
                              HorizontalAlignment="Center" />
                <TextBlock x:Uid="SetupOverlay_Title" HorizontalAlignment="Center"
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="SetupOverlay_Description" HorizontalAlignment="Center"
                           Style="{ThemeResource BodyTextBlockStyle}" Opacity="0.7"
                           TextAlignment="Center" TextWrapping="Wrap" />
                <TextBlock x:Name="SetupLogTextBlock" HorizontalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"
                           FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="16,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock x:Name="StatusBarTextBlock" Grid.Column="0"
                           Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />

                <Button x:Name="SkeletonScreenToggleButton" Grid.Column="1"
                        x:Uid="MainWindow_SkeletonScreenToggleButton"
                        Style="{StaticResource StatusBarIconButtonStyle}"
                        Margin="0,0,16,0" Click="SkeletonScreenToggleButton_Click">
                    <FontIcon x:Name="SkeletonScreenToggleIcon" Glyph="&#xE7B3;" FontSize="14" />
                </Button>

                <StackPanel x:Name="SystemStatsPanel" Grid.Column="2" Orientation="Horizontal"
                            Spacing="12" Margin="0,0,16,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7"
                                ToolTipService.ToolTip="CPU">
                        <FontIcon Glyph="&#xE950;" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="CpuUsageTextBlock" Width="32"
                                   TextAlignment="Right"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.7"
                                ToolTipService.ToolTip="Memory">
                        <FontIcon Glyph="&#xEEA1;" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="MemoryUsageTextBlock" Width="88"
                                   TextAlignment="Right"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel x:Name="GpuStatsPanel" Orientation="Horizontal" Spacing="4"
                                Opacity="0.7" Visibility="Collapsed" ToolTipService.ToolTip="GPU">
                        <FontIcon Glyph="&#xE7F4;" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="GpuUsageTextBlock" Width="32"
                                   TextAlignment="Right"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel x:Name="VramStatsPanel" Orientation="Horizontal" Spacing="4"
                                Opacity="0.7" Visibility="Collapsed" ToolTipService.ToolTip="VRAM">
                        <FontIcon Glyph="&#xE9D9;" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock x:Name="VramUsageTextBlock" Width="88"
                                   TextAlignment="Right"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <HyperlinkButton x:Name="GalleryButton" Grid.Column="3"
                                 Padding="0" Margin="0,0,16,0" IsEnabled="False" Click="GalleryButton_Click">
                    <TextBlock x:Uid="MainWindow_GalleryButtonLabel"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7" />
                </HyperlinkButton>
                <HyperlinkButton x:Name="ModelSelectionButton" Grid.Column="4"
                                 Padding="0" IsEnabled="False" Click="ModelSelectionButton_Click">
                    <TextBlock x:Name="StatusBarDeviceInfoTextBlock"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5" />
                </HyperlinkButton>
            </Grid>
        </Border>
    </Grid>
</Window>
