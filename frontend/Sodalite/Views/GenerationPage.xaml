<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Sodalite.Views.GenerationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SkeletonBaseBrush" Color="#FFD0D0D0" />
                    <Color x:Key="SkeletonShimmerColor">#FFF5F5F5</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SkeletonBaseBrush" Color="#FF3A3A3A" />
                    <Color x:Key="SkeletonShimmerColor">#FF5A5A5A</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid ColumnDefinitions="420,*" Padding="20" ColumnSpacing="20">
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Generation_PromptLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="PromptTextBox" x:Uid="Generation_PromptTextBox" AcceptsReturn="True" Height="100"
                         TextWrapping="Wrap" />

                <TextBlock x:Uid="Generation_NegativePromptLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="NegativePromptTextBox" x:Uid="Generation_NegativePromptTextBox" AcceptsReturn="True" Height="70"
                         TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Generation_SamplerLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox x:Name="SamplerComboBox" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Generation_SeedLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox x:Name="SeedTextBox" x:Uid="Generation_SeedTextBox" />
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock x:Uid="Generation_StepsLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Slider x:Name="StepsSlider" Minimum="1" Maximum="150" Value="20"
                            TickFrequency="10" ValueChanged="StepsSlider_ValueChanged" />
                    <TextBlock x:Name="StepsValueTextBlock" Text="20" Opacity="0.7" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock x:Uid="Generation_CfgScaleLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Slider x:Name="CfgScaleSlider" Minimum="0" Maximum="30" Value="7"
                            StepFrequency="0.5" TickFrequency="5" ValueChanged="CfgScaleSlider_ValueChanged" />
                    <TextBlock x:Name="CfgScaleValueTextBlock" Text="7.0" Opacity="0.7" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Generation_WidthLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <NumberBox x:Name="WidthNumberBox" Minimum="64" Maximum="2048"
                                   SmallChange="8" LargeChange="64" Value="1024"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Generation_HeightLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <NumberBox x:Name="HeightNumberBox" Minimum="64" Maximum="2048"
                                   SmallChange="8" LargeChange="64" Value="1024"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock x:Uid="Generation_BatchSizeLabel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <NumberBox x:Name="BatchSizeNumberBox" Minimum="1" Maximum="120"
                                   SmallChange="1" LargeChange="10" Value="1"
                                   SpinButtonPlacementMode="Compact" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Button x:Name="GenerateButton" HorizontalAlignment="Stretch"
                            Style="{ThemeResource AccentButtonStyle}" Click="GenerateButton_Click" IsEnabled="False" />
                    <Button x:Name="CancelButton" x:Uid="Generation_CancelButton" HorizontalAlignment="Stretch"
                            Click="CancelButton_Click" Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" RowDefinitions="*,Auto">
            <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                <Grid>
                    <Image x:Name="ResultImageControl" Stretch="Uniform" Margin="8">
                        <Image.ContextFlyout>
                            <MenuFlyout Opening="ResultImageFlyout_Opening">
                                <MenuFlyoutItem x:Name="CopyImageMenuItem" x:Uid="Generation_CopyImageMenuItem"
                                                Click="CopyImageMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SaveImageMenuItem" x:Uid="Generation_SaveImageMenuItem"
                                                Click="SaveImageMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Save" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="OpenContainingFolderMenuItem" x:Uid="Generation_OpenContainingFolderMenuItem"
                                                Click="OpenContainingFolderMenuItem_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Folder" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Image.ContextFlyout>
                    </Image>

                    <Grid x:Name="SkeletonScreenGrid" Visibility="Collapsed" Margin="8"
                          SizeChanged="SkeletonScreenGrid_SizeChanged">
                        <Border x:Name="SkeletonScreenBorder" CornerRadius="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="{ThemeResource SkeletonBaseBrush}">
                            <Grid>
                                <Grid.Clip>
                                    <RectangleGeometry x:Name="SkeletonClipGeometry" />
                                </Grid.Clip>
                                <Rectangle x:Name="SkeletonShimmerRectangle" Width="200">
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="SkeletonShimmerTransform" X="-200" />
                                    </Rectangle.RenderTransform>
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0.0" Color="Transparent" />
                                            <GradientStop Offset="0.5" Color="{ThemeResource SkeletonShimmerColor}" />
                                            <GradientStop Offset="1.0" Color="Transparent" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                        </Border>
                        <Grid.Resources>
                            <Storyboard x:Name="SkeletonShimmerStoryboard" RepeatBehavior="Forever">
                                <DoubleAnimation x:Name="SkeletonShimmerAnimation"
                                                  Storyboard.TargetName="SkeletonShimmerTransform"
                                                  Storyboard.TargetProperty="X"
                                                  Duration="0:0:1.2">
                                    <DoubleAnimation.EasingFunction>
                                        <SineEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </Grid.Resources>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
