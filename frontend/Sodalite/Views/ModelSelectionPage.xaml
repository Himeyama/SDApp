<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Sodalite.Views.ModelSelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Sodalite.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Sodalite.ViewModels"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,*" Padding="20" RowSpacing="16">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button x:Name="BackButton" x:Uid="ModelSelectionPage_BackButton"
                    Background="Transparent" BorderThickness="0" Padding="8"
                    Click="BackButton_Click">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>
            <TextBlock x:Uid="ModelSelectionPage_Title"
                       Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <InfoBar Grid.Row="0" x:Name="ErrorInfoBar" Severity="Error" IsOpen="False"
                     Margin="0,0,0,12" />

            <!-- 左: ベースモデル / 右: LoRA の 2 カラム。 -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="24">
                <!-- ベースモデル -->
                <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" x:Uid="ModelSelectionDialog_ModelHeader"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Uid="ModelSelectionPage_ChooseModelDirButton"
                                Click="ChooseModelDirButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock x:Uid="ModelSelectionPage_ChooseFolderLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" x:Name="ModelDirTextBlock" x:Uid="ModelSelectionPage_ModelDirUnset"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"
                               Margin="0,0,0,8" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                    <Grid Grid.Row="2">
                        <ProgressRing x:Name="LoadingProgressRing" IsActive="False"
                                      HorizontalAlignment="Left" VerticalAlignment="Top" Width="24" Height="24" />

                        <ListView x:Name="ModelListView"
                                  SelectionMode="Single" SelectionChanged="ModelListView_SelectionChanged"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <!-- 項目をリスト幅いっぱいに広げ、長いモデル名を省略表示にする。 -->
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ModelListItem">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <TextBlock Grid.Column="0" Text="{x:Bind DisplayName}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MinWidth="0"
                                                   ToolTipService.ToolTip="{x:Bind ModelId}" />
                                        <FontIcon Grid.Column="1" Glyph="&#xE73E;" FontSize="14"
                                                  VerticalAlignment="Center" Visibility="{x:Bind ActiveVisibility}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <!-- LoRA -->
                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" x:Uid="ModelSelectionDialog_LoraHeader"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Uid="ModelSelectionPage_ChooseLoraDirButton"
                                Click="ChooseLoraDirButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock x:Uid="ModelSelectionPage_ChooseFolderLabel" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="AddLoraButton"
                                x:Uid="ModelSelectionDialog_AddLoraButtonTooltip">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <Button.Flyout>
                                <MenuFlyout x:Name="AddLoraMenuFlyout" />
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" x:Name="LoraDirTextBlock" x:Uid="ModelSelectionPage_LoraDirUnset"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.7"
                               Margin="0,0,0,4" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />

                    <TextBlock Grid.Row="2" x:Uid="ModelSelectionDialog_LoraEmpty" x:Name="LoraEmptyTextBlock"
                               Style="{ThemeResource CaptionTextBlockStyle}" Opacity="0.5"
                               Margin="0,4,0,0" />

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <ItemsControl x:Name="SelectedLoraItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelectedLoraViewModel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{Binding LoraId}" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <Slider Grid.Column="0" Minimum="-2" Maximum="2" StepFrequency="0.05"
                                                        Value="{Binding Weight, Mode=TwoWay}" />
                                                <TextBlock Grid.Column="1" Width="36" TextAlignment="Right"
                                                           VerticalAlignment="Center" Opacity="0.7"
                                                           Text="{Binding WeightText}" />
                                            </Grid>
                                        </StackPanel>
                                        <Button Grid.Column="1" VerticalAlignment="Top"
                                                Click="RemoveLoraButton_Click" DataContext="{Binding}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
